# Postgres — em produção use a connection string do Managed Postgres da DigitalOcean.
# DATABASE_URL usa o pool; DIRECT_URL é a conexão direta (para migrações).
DATABASE_URL="postgresql://user:pass@host:5432/gazeta?sslmode=require"
DIRECT_URL="postgresql://user:pass@host:5432/gazeta?sslmode=require"

# Allowlist de remetentes da SECOM (vírgula-separado). Vazio = aceita todos (só dev).
SECOM_ALLOWLIST="secom@santanadeparnaiba.sp.gov.br"

# Segredo do webhook de inbound e-mail (o provedor envia no header x-webhook-secret).
INBOUND_WEBHOOK_SECRET="troque-por-um-segredo-forte"

# Token Bearer das rotas /api/admin. Vazio = liberado (só dev).
ADMIN_TOKEN="troque-por-um-token-forte"
